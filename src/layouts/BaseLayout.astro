---
/**
 * BaseLayout — HTML document shell.
 *
 * Replaces the old index.html entry point.
 * Handles: charset, viewport, meta, fonts, favicon,
 * Netlify hidden form, and global CSS import.
 */

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Small World Media™',
  description = 'Small World Media — Visual worlds for the music industry. Multi-disciplinary creative studio specializing in visual identity, motion design, and digital experiences.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    {/* Google Fonts: Inter (UI font stack) */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&display=swap"
      rel="stylesheet"
    />

    {/* Favicons */}
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  </head>

  <body>
    {/* Hidden form for Netlify's deploy parser (SPA detection) */}
    <form name="contact" netlify netlify-honeypot="bot-field" hidden>
      <input name="bot-field" />
      <input name="name" />
      <input name="email" />
      <input name="project" />
      <textarea name="message"></textarea>
    </form>

    <slot />
  </body>
</html>
